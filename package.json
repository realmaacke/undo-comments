{
  "name": "undo-comments",
  "version": "1.0.4",
  "description": "Removes JSON comments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },

  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realmaacke/undo-comments.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "json",
    "remove",
    "comments",
    "undo"
  ],
  "author": "realmaacke",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/realmaacke/undo-comments/issues"
  },
  "homepage": "https://github.com/realmaacke/undo-comments#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
